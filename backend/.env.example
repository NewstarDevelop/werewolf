# ── Core ──────────────────────────────────────
APP_NAME=Werewolf
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
DATABASE_URL=sqlite+aiosqlite:///./werewolf.db

# ── JWT ───────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Auth ──────────────────────────────────────
ADMIN_PASSWORD=

# ── OAuth: linux.do ───────────────────────────
OAUTH_LINUXDO_CLIENT_ID=
OAUTH_LINUXDO_CLIENT_SECRET=
OAUTH_LINUXDO_REDIRECT_URI=

# ── LLM Default ──────────────────────────────
LLM_DEFAULT_PROVIDER=mock
LLM_DEFAULT_API_KEY=
LLM_DEFAULT_MODEL=
LLM_DEFAULT_BASE_URL=
LLM_DEFAULT_TEMPERATURE=0.7
LLM_DEFAULT_MAX_TOKENS=1024

# ── LLM Analysis ─────────────────────────────
LLM_ANALYSIS_PROVIDER=
LLM_ANALYSIS_API_KEY=
LLM_ANALYSIS_MODEL=

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_PER_MINUTE=30
LLM_RATE_LIMIT_PER_MINUTE=10

# ── Redis (optional) ─────────────────────────
REDIS_URL=

# ── Admin Features ────────────────────────────
ADMIN_ENV_EDIT_ENABLED=false
UPDATE_AGENT_ENABLED=false
UPDATE_AGENT_TOKEN=
